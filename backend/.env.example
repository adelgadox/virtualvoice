DATABASE_URL=postgresql://virtualvoice:virtualvoice@localhost:5432/virtualvoice
# Set to true when a PgBouncer proxy sits in front of PostgreSQL (Railway add-on).
PGBOUNCER_MODE=false

SECRET_KEY=change-me-in-production
DEBUG=true
FRONTEND_URL=http://localhost:3000

# Proxy — set to "*" on Railway
TRUSTED_PROXY_IPS=127.0.0.1

# LLM Providers
LLM_PROVIDER=gemini
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Google OAuth (SSO)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Meta / Facebook Graph API
META_APP_ID=
META_APP_SECRET=
META_WEBHOOK_VERIFY_TOKEN=change-me-in-production
